{
  "name": "schema-validator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build:static": "npm run build",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings=0",
